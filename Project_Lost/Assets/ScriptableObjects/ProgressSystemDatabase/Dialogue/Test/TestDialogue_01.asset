  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u30A2\u30BF\u30B7\u306F<color=#ff7b00>\u30AB\u30C1\u30E7\u30A6</color>\u3002\n\u3066\u3059\u3068\u3077\u308C\u3044\u306E\u9032\u884C\u5F79\u3092\u4EFB\u3055\u308C\u3066\u308B\u5E74\u5BC4\u308A\u3060\u3002"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u30B2\u30FC\u30E0\u306E\u6982\u8981\u306F\u3055\u3063\u304D\u8AAC\u660E\u3055\u308C\u3066\u308B\u7B48\u3060\u304B\u3089\u306D\u3002\n...\u624B\u7B48\u901A\u308A\u306A\u3089\u3002"
