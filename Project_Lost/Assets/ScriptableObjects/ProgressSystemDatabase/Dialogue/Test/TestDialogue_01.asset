  - speakerName: "\uFF1F\uFF1F\uFF1F"
    text: "\u672C\u6765\u306F\u3082\u3063\u3068\u9577\u3044\u904E\u7A0B\u304C\u3042\u308B\u3093\u3060\u304C\u306A\u3002\n\u3066\u3059\u3068\u3077\u308C\u3044\u3068\u3084\u3089\u306B\u306F\u5FC5\u8981\u306A\u3044\u3089\u3057\u3044\u3002"
