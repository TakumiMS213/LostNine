    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u307B\u3093\u3067\u4ECA\u306F\u30D7\u30ED\u30ED\u30FC\u30B0\u30D5\u30A7\u30FC\u30BA\u3001\u524D\u7F6E\u304D\u3060\u3002"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u3053\u306E\u30E1\u30C3\u30BB\u30FC\u30B8\u30A6\u30A3\u30F3\u30C9\u30A6\u304C\u9589\u3058\u305F\u5F8C\u306B<color=#ff7b00>\u30A2\u30BF\u30B7\u3092\u30AF\u30EA\u30C3\u30AF</color>\u3059\u308C\u3070\u3001\u6B21\u306B\u9032\u3081\u308B\u3002\u3084\u3063\u3066\u307F\u306A\u3002"
