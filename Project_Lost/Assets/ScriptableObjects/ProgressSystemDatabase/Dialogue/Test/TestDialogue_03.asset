  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u3053\u306E\u30D5\u30A7\u30FC\u30BA\u306F\u30AD\u30FC\u30EF\u30FC\u30C9\u3092\u5168\u3066\u898B\u3064\u3051\u308B\u307E\u3067\u30BB\u30EA\u30D5\u304C\u7E70\u308A\u8FD4\u3055\u308C\u308B\u3088\u3046\u306B\u306A\u3063\u3066\u3093\u3060\u3002"
