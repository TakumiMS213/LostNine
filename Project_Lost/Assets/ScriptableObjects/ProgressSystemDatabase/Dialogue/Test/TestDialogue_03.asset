  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u4ECA\u306E\u8A71\u3082\u7E70\u308A\u8FD4\u3055\u308C\u308B\u304C\u3001<link=\"Data3\">\u9023\u6253</link>\u3057\u3066\u308C\u3070\u3059\u3063\u98DB\u3070\u305B\u308B\u304B\u3089\u5B89\u5FC3\u3057\u306A\u3002"
