    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u30AB\u30C3\u30B3\u3064\u3051\u3061\u3083\u3044\u308B\u304C\u3001\u8981\u306F\"\u306A\u304F\u3057\u3082\u306E\"\u3092\u6271\u3046\u90E8\u7F72\u3063\u3066\u30EF\u30B1\u3060\u306A\u3002"
