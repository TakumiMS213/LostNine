  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u305D\u3046\u3002\u30A2\u30BF\u30B7\u306E\u4ED5\u4E8B\u306F\u3010\u907A\u5931\u7269\u3011\u306B\u95A2\u3059\u308B\u30E2\u30F3\u3060\u3002"
