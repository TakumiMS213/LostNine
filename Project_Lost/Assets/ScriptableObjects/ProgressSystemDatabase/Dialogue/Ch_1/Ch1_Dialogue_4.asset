  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u5177\u4F53\u7684\u306A\u4ED5\u4E8B\u5185\u5BB9\u306B\u95A2\u3057\u3066\u306F....\u3001\u307E\u3042\u5B9F\u969B\u306B\u3084\u3063\u3066\u307F\u308B\u307B\u3046\u304C\u65E9\u3044\u3060\u308D\u3046\u3002"
