  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u3067\u3082\u305F\u3060\u306E\"\u306A\u304F\u3057\u3082\u306E\"\u3058\u3083\u3042\u306A\u3044\u3002"
