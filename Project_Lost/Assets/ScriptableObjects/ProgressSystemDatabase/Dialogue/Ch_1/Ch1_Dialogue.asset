    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\uFF1F\uFF1F\uFF1F"
    text: "....\u3002"
    portrait: {fileID: 0}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u6E21\u3057\u5B88"
    text: "\u7740\u3044\u305F\u5148\u3067\u4F55\u304C\u8D77\u3053\u308B\u304B\u306F\u3001\u304A\u5BA2\u3055\u3093\u6B21\u7B2C\u3067\u3055\u30A1\u3002"
    portrait: {fileID: 0}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\uFF1F\uFF1F\uFF1F"
    text: "....\u3001..........\u3002"
    portrait: {fileID: 0}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u6E21\u3057\u5B88"
    text: "...\u6700\u671F\u306B\u3001\u4F55\u304B\u8A00\u3044\u6B8B\u3059\u3053\u3068\u306F\u3042\u308A\u3084\u3059\u304B\uFF1F"
    portrait: {fileID: 0}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u6E21\u3057\u5B88"
    text: "\u304A\u3063\u3068\u3001\u3053\u308C\u3058\u3083\u30A1\u307E\u308B\u3067\u3042\u3063\u3057\u304C\"\u60AA\u5F79\"\u306E\u3088\u3046\u3067\u3002"
    portrait: {fileID: 0}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u6E21\u3057\u5B88"
    text: "\u4F55\u304B\u3001\u5F8C\u306B\u6765\u308B\u304A\u5BA2\u3055\u3093\u306B\u4F1D\u3048\u305F\u3044\u4E8B\u304C\u3042\u308C\u3070\u304A\u4F1D\u3048\u3057\u307E\u3057\u3087\u3046\u3002"
    portrait: {fileID: 0}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\uFF1F\uFF1F\uFF1F"
    text: .......?
    portrait: {fileID: 0}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u6E21\u3057\u5B88"
    text: "\u306A\u306B\u3001\u3042\u3063\u3057\u304B\u3089\u306E\u3055\u3055\u3084\u304B\u306A\u6C17\u3065\u304B\u3044\u3067\u3055\u30A1\u3002"
    portrait: {fileID: 0}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u6E21\u3057\u5B88"
    text: "...\u304A\u5BA2\u3055\u3093\u306F\u3001\u4F55\u304B\u5F37\u3044\u672A\u7DF4\u304C\u3042\u308B\u3088\u3046\u306B\u898B\u3048\u307E\u3057\u3066\u306D\u3002"
    portrait: {fileID: 0}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\uFF1F\uFF1F\uFF1F"
    text: ".....................\u3002"
    portrait: {fileID: 0}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u6E21\u3057\u5B88"
    text: "...\u3048\u3047\u3001\u627F\u308A\u307E\u3057\u305F\u3002\u78BA\u304B\u306B\u3001\u304A\u4F1D\u3048\u3044\u305F\u3057\u3084\u3059\u3002"
    portrait: {fileID: 0}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u6E21\u3057\u5B88"
    text: "\u3042\u3042\u3001\u305D\u308C\u3068\u6700\u671F\u306B\u3002"
    portrait: {fileID: 0}
    portraitPosition: 0
    typingSpeed: 0
