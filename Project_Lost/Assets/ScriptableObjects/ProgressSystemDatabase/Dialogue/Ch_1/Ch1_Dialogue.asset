    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u6E21\u3057\u5B88"
    text: "\u5411\u3053\u3046\u5CB8\u306B\u8E0F\u307F\u5165\u308C\u308C\u3070\u3001\u3053\u308C\u307E\u3067\u306E\u8A18\u61B6\u306F\u4E00\u5207\u5408\u5207\u306A\u304F\u306A\u308A\u3084\u3059\u3002"
