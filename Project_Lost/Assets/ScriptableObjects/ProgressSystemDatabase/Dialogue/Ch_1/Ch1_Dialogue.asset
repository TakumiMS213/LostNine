  entries:
  - speakerName: "\u6E21\u3057\u5B88"
    text: "\u304A\u5BA2\u3055\u3093\u3002\u305D\u308D\u305D\u308D\u5411\u3053\u3046\u5CB8\u306B\u7740\u304D\u3084\u3059\u305C\u3002"
    portrait: {fileID: 0}
