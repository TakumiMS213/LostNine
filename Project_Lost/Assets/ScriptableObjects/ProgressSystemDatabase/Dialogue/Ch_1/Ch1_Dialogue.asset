  - speakerName: "\uFF1F\uFF1F\uFF1F"
    text: "\u7A7A\u306F\u4E00\u5411\u306B\u660E\u308B\u304F\u306A\u3089\u306A\u3044\u3002\n\u305D\u308C\u3069\u3053\u308D\u304B\u3001\u6697\u3055\u3092\u5897\u3057\u3066\u3044\u308B\u3088\u3046\u306B\u898B\u3048\u3066\u2015\u2015"
