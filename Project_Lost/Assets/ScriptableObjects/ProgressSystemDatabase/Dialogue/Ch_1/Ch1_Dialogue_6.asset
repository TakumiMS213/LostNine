  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u3055\u3066\u3001\u524D\u4E16\u306E\u8A18\u61B6\u3092\u623B\u3059\u305F\u3081\u306B\u306F\u3001\u30C8\u30EA\u30AC\u30FC\u3068\u306A\u308B\u30A2\u30A4\u30C6\u30E0...\"\u306A\u304F\u3057\u3082\u306E\"\u304C\u5FC5\u8981\u3060\u3002"
