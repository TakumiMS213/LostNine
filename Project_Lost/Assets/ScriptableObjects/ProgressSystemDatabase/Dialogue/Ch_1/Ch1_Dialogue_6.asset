  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u30E1\u30E2\u30E9\u30A4\u30B6\u30FC\u3092\u901A\u3057\u3066\u30A2\u30BF\u30B7\u3092\u898B\u308B\u3068\u3001\u7279\u5FB4\u7684\u306A\u30BB\u30EA\u30D5\u304C\u898B\u3064\u304B\u308B\u306F\u305A\u3060\u3002"
