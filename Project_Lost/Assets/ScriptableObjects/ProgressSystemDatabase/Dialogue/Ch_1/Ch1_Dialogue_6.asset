  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u3053\u3053\u3001\u300C\u907A\u5931\u7269\u7BA1\u7406\u8AB2\u300D\u306E\u5F79\u76EE\u306F\u3001\u9B42\u306E\u907A\u5931\u7269\u3001\u3059\u306A\u308F\u3061\"\u524D\u4E16\u306E\u8A18\u61B6\"\u3092\u8FD4\u3059\u4E8B\u3060\u3002"
