  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u305D\u308C\u306F\u300C\u30E1\u30E2\u30E9\u30A4\u30B6\u30FC\u300D\u3068\u8A00\u3063\u3066\u306A\u3002\u9069\u5207\u306A\u624B\u9806\u3092\u8E0F\u3080\u3053\u3068\u3067\u3001\"\u306A\u304F\u3057\u3082\u306E\"\u3092\u7279\u5B9A\u3067\u304D\u308B\u7279\u5225\u88FD\u3060\u3002"
