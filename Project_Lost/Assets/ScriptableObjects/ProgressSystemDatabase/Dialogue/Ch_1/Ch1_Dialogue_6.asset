  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u4ECA\u56DE\u306F\u3001\u30A2\u30BF\u30B7\u304C\u30CA\u30AF\u30B7\u30D3\u30C8\u306E\u5F79\u3060\u3002"
