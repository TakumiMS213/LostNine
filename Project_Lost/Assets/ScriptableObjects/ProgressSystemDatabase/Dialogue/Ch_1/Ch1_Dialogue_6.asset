  - speakerName: "\u30D2\u30A4\u30E9\u30AE"
    text: "\"\u524D\u4E16\u306E\u8A18\u61B6\"....?\u305D\u3046\u3044\u3048\u3070\u3001\u79C1\u3082\u8A18\u61B6\u304C\u3042\u308A\u307E\u305B\u3093\u3067\u3057\u305F\u306D\u3002"
