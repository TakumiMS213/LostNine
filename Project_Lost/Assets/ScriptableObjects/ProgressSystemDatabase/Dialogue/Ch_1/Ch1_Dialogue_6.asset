    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u305D\u308C\u3092\u7279\u5B9A\u3059\u308B\u305F\u3081\u306B\u5FC5\u8981\u306A\u306E\u304C\u3001\u305D\u306E\u5199\u771F\u6A5F\u3060\u3002"
