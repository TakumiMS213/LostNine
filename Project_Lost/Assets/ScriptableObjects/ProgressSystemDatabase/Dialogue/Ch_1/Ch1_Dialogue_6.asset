  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u305D\u308C\u3067\"\u306A\u304F\u3057\u3082\u306E\"\u3092\u898B\u3064\u3051\u308B\u4F5C\u696D....\u305D\u308C\u3092\u300C\u73FE\u50CF\uFF08\u30E1\u30E2\u30E9\u30A4\u30BA\uFF09\u300D\u3068\u3044\u3046\u3002"
