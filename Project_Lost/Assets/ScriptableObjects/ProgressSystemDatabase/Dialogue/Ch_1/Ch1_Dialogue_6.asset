    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u72ED\u9593\u5E02\u306B\u6765\u305F\u5974\u306F\u3001\u307F\u3093\u306A\u8A18\u61B6\u3092\u5931\u3046\u304B\u3089\u306A\u3002"
