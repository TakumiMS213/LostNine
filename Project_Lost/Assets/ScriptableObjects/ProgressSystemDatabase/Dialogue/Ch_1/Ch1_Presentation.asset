  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u3060\u304B\u3089\"\u306A\u304F\u3057\u3082\u306E\"\u306F\u305D\u3044\u3064\u306E\u524D\u4E16\u3092\u8C61\u5FB4\u3059\u308B\u3082\u306E\u3067\u3042\u308B\u53EF\u80FD\u6027\u304C\u9AD8\u3044\u3002"
