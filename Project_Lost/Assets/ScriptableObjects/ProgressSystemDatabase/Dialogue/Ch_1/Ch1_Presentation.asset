  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u306A\u304F\u3057\u3082\u306E\u3092\u898B\u3064\u3051\u3066\u3001\u524D\u4E16\u306E\u8A18\u61B6\u3092\u547C\u3073\u8D77\u3053\u3059\u306E\u304C\u91CD\u8981\u3060\u3002"
