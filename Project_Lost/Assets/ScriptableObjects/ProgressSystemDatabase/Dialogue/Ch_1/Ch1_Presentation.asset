  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u72ED\u9593\u5E02\u306F\u671B\u3093\u3060\u59FF\u306B\u6210\u308C\u308B\u5834\u6240\u3060\u3002"
