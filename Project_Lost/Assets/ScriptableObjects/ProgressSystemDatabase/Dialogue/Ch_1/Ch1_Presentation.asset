  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u305D\u3046\u304B\u3044\u3002\u3058\u3083\u3042\u3001\u6700\u5F8C\u306B\u30A2\u30C9\u30D0\u30A4\u30B9\u3060\u3051\u3057\u3066\u3084\u308B\u3002"
