  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u30A2\u30BF\u30B7\u305F\u3061\u306F\"\u306A\u304F\u3057\u3082\u306E\"\u3092\u898B\u3064\u3051\u308B\u306E\u304C\u4ED5\u4E8B\u3060\u304C\u3001\u5927\u4E8B\u306A\u306E\u306F\u305D\u3053\u3058\u3083\u306A\u3044\u3002"
