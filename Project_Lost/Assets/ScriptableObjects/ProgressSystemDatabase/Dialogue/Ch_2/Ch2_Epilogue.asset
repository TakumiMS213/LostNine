%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d1419a330f93d40d0a6036a06f49986d, type: 3}
  m_Name: Ch2_Epilogue
  m_EditorClassIdentifier: 
  entries:
  - speakerName: "カチョウ"
    text: "あぁ、言ってなかったか。"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "カチョウ"
    text: "前世の記憶を思い出したやつは狭間市から消える。"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "ヒイラギ"
    text: "....え？"
    portrait: {fileID: 21300000, guid: 08f06e70be29a8844ad85a9db05083a6, type: 3}
    portraitPosition: 2
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "カチョウ"
    text: "魂の未練が消えて、新しい命に転生するんだ。"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "カチョウ"
    text: "自分のせいとでも思ってるのか。"
    portrait: {fileID: 21300000, guid: 3e9209ca9223746229eb325d4a7984f9, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "カチョウ"
    text: "遺失物管理課は、前世の記憶を思い出させる場所。"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "カチョウ"
    text: "そして、前世の記憶を思い出した奴は狭間市から消える。"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "カチョウ"
    text: "狭間市に囚われている魂の解放、と言い換えてもいい。"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "カチョウ"
    text: "これは、正しい事だ。"
    portrait: {fileID: 21300000, guid: 3e9209ca9223746229eb325d4a7984f9, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "カチョウ"
    text: "...改めて言おう。"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "カチョウ"
    text: "ようこそ、\"狭間市役所　遺失物管理課\"へ。"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
