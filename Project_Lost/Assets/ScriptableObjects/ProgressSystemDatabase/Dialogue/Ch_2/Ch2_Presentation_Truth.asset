  entries:
  - speakerName: "\u30D2\u30A4\u30E9\u30AE"
    text: "\u30EA\u30C9\u3055\u3093\u3002\u3053\u308C\u306F\u3001\u3042\u306A\u305F\u304C\u751F\u304D\u3066\u3044\u305F\u5834\u6240\u306E\u8449\u3067\u3059\u3002\u3042\u306A\u305F\u306F\u2026\u2026\u30EF\u30BF\u30EA\u30C9\u30EA\u3067\u306F\u3042\u308A\u307E\u305B\u3093\u3067\u3057\u305F\u3002"
    portrait: {fileID: 21300000, guid: 174500ec22662be46b815ee34892036d, type: 3}
    portraitPosition: 2
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 21300000, guid: 46ba3d3eeddf56c4a98e1affe0a01baa, type: 3}
  - speakerName: "\u30EA\u30C9"
    text: "\u2026\u2026\u30DC\u30AF\u306F\u9CE5\u3058\u3083\u306A\u304B\u3063\u305F\u3002\u305F\u3060\u306E\u3001\u60E8\u3081\u306A\u866B\u3060\u3063\u305F\u3093\u3060\u306D\u3002"
    portrait: {fileID: 21300000, guid: 4b3a70eb92a7f7149b01cc2968185357, type: 3}
    portraitPosition: 1
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 21300000, guid: 46ba3d3eeddf56c4a98e1affe0a01baa, type: 3}
  - speakerName: "\u30EA\u30C9"
    text: "\u9CE5\u306B\u602F\u3048\u3001\u9CE5\u306B\u55B0\u308F\u308C\u3066\u6B7B\u3093\u3060\u3001\u305F\u3060\u306E\u866B\u2026\u2026\u3002"
    portrait: {fileID: 21300000, guid: 4b3a70eb92a7f7149b01cc2968185357, type: 3}
    portraitPosition: 1
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 21300000, guid: 46ba3d3eeddf56c4a98e1affe0a01baa, type: 3}
  - speakerName: "\u30D2\u30A4\u30E9\u30AE"
    text: "\u3067\u3082\u3001\u7A7A\u306B\u61A7\u308C\u305F\u6C17\u6301\u3061\u306F\u5618\u3058\u3083\u3042\u308A\u307E\u305B\u3093\u3002\u6016\u304B\u3063\u305F\u3053\u3068\u3082\u3001\u60E8\u3081\u3060\u3063\u305F\u3053\u3068\u3082\u3001\u3042\u306A\u305F\u306E\u4E00\u90E8\u3067\u3059\u3002"
    portrait: {fileID: 21300000, guid: 174500ec22662be46b815ee34892036d, type: 3}
    portraitPosition: 2
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 21300000, guid: 46ba3d3eeddf56c4a98e1affe0a01baa, type: 3}
  - speakerName: "\u30EA\u30C9"
    text: "\u3067\u3082\u2026\u2026\u4E0D\u601D\u8B70\u3068\u3001\u3082\u3046\u3042\u306E\u30B8\u30E1\u30B8\u30E1\u3057\u305F\u68EE\u304C\u6016\u304F\u306A\u3044\u3084\u3002"
    portrait: {fileID: 21300000, guid: 4b3a70eb92a7f7149b01cc2968185357, type: 3}
    portraitPosition: 1
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: -3590566777017096083, guid: ffe0f79a1be1bc745ba03d7de9427399, type: 3}
  - speakerName: "\u30EA\u30C9"
    text: "\u3042\u308A\u304C\u3068\u3001\u304A\u59C9\u3055\u3093\u3002\u6B21\u306F\u2026\u2026\u6B21\u306F\u512A\u3057\u3044\u5618\u3058\u3083\u306A\u304F\u3066\u3001\u672C\u5F53\u306B\u3001\u81EA\u5206\u306E\u7FFC\u3067\u3001\u3042\u306E\u5E83\u3044\u7A7A\u3092\u98DB\u3093\u3067\u307F\u305B\u308B\u3088\u3002"
    portrait: {fileID: 21300000, guid: 18f1e5e075c94174f8da7df44219d63f, type: 3}
    portraitPosition: 1
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 21300000, guid: 8f6b3314d28181b40888c6cece606878, type: 3}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u9B42\u306E\u6B6A\u307F\u306F\u629C\u3051\u305F\u3002\u30ED\u30B9\u306F\u307B\u3068\u3093\u3069\u306A\u3044\u3002\u2026\u2026\u4E0A\u51FA\u6765\u3060\u3002"
