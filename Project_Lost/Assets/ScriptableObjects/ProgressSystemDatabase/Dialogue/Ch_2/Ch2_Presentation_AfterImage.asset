    backgroundImage: {fileID: 0}
  - speakerName: "\u30EA\u30C9"
    text: "\u30DC\u30AF\u306F\u3053\u306E\u8857\u306B\u6765\u308B\u524D\u3001\n\"\u5730\u3092\u9019\u3046\u828B\u866B\"\u3060\u3063\u305F\u3093\u3060\u3002"
