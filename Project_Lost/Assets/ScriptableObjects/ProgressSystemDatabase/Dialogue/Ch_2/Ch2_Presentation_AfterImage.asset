    portraitPosition: 0
    typingSpeed: 0.12
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30EA\u30C9"
    text: "\u300C\u3082\u3046\u3001\u9019\u3044\u3064\u304F\u3070\u308B\u3060\u3051\u306E\u81EA\u5206\u306F\u5ACC\u3060\u3002\u300D"
    portrait: {fileID: 21300000, guid: d81d794e3f1b3064db4509b0df92be92, type: 3}
    portraitPosition: 0
    typingSpeed: 0.12
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30EA\u30C9"
    text: "\u305D\u3046\u601D\u3063\u3066\u3001\u7A7A\u3092\u81EA\u7531\u306B\u99C6\u3051\u3089\u308C\u308B\u3053\u306E\u59FF\u3092\u9858\u3063\u305F\u306E\u306B\u3002"
    portrait: {fileID: 21300000, guid: d81d794e3f1b3064db4509b0df92be92, type: 3}
    portraitPosition: 0
    typingSpeed: 0.12
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30D2\u30A4\u30E9\u30AE"
    text: "...\u3048\uFF1F\u305D\u3001\u305D\u3093\u306A...."
