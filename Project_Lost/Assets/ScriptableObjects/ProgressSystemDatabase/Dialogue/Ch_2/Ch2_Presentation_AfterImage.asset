    backgroundImage: {fileID: 0}
  - speakerName: "\u30D2\u30A4\u30E9\u30AE"
    text: "\u305D\u3093\u306A\u3064\u3082\u308A\u3058\u3083...\u306A\u304B\u3063\u305F\u3093\u3067\u3059\u3088\u3002"
