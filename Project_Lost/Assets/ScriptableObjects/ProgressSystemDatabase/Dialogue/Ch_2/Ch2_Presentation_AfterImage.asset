  - speakerName: "\u30D2\u30A4\u30E9\u30AE"
    text: "\u5FD8\u308C\u305F\u904E\u53BB\u3092\u3001\u601D\u3044\u51FA\u305B\u305F\u3089\u3001\u3044\u3044\u306A\u3063\u3066....\u3002"
