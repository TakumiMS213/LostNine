  entries:
  - speakerName: "\u30EA\u30C9"
    text: "\u3042\u2026\u2026\u3042\u3042\u2026\u2026\u982D\u304C\u3001\u75DB\u3044\u2026\u2026\uFF01\u3000\u9055\u3046\u3001\u30DC\u30AF\u306F\u3001\u3053\u306E\u8449\u3063\u3071\u306E\u4E0A\u304C\u4E16\u754C\u306E\u3059\u3079\u3066\u3067\u2026\u2026\u3002"
