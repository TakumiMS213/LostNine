  - speakerName: "\u30EA\u30C9"
    text: "\u304A\u8179\u304C\u7A7A\u3044\u3066\u3001\u305F\u3060\u304C\u3080\u3057\u3083\u3089\u306B\u7DD1\u3092\u9F67\u3063\u3066\u3001\u6CE5\u306B\u307E\u307F\u308C\u3066\u751F\u304D\u3066\u2026\u2026\u3002"
    portrait: {fileID: 21300000, guid: 4b3a70eb92a7f7149b01cc2968185357, type: 3}
    portraitPosition: 1
    typingSpeed: 0.035
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: -3590566777017096083, guid: ffe0f79a1be1bc745ba03d7de9427399, type: 3}
  - speakerName: "\u30EA\u30C9"
    text: "\u3042\u306E\u65E5\u3001\u6025\u306B\u4E0A\u7A7A\u304C\u6697\u304F\u306A\u3063\u305F\u3002\u5927\u304D\u306A\u3001\u5927\u304D\u306A\u5F71\u3002"
    portrait: {fileID: 21300000, guid: d81d794e3f1b3064db4509b0df92be92, type: 3}
    portraitPosition: 1
