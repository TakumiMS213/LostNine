    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: -3590566777017096083, guid: ffe0f79a1be1bc745ba03d7de9427399, type: 3}
  - speakerName: "\u30EA\u30C9"
    text: "<size=120%>\u75DB\u3044\u3001\u75DB\u3044\u3001\u75DB\u3044\uFF01\uFF01</size>\u3000\u92ED\u3044\u304F\u3061\u3070\u3057\u304C\u3001\u30DC\u30AF\u306E\u8EAB\u4F53\u3092\u30D0\u30E9\u30D0\u30E9\u306B\u2015\u2015\uFF01\uFF01"
    portrait: {fileID: 21300000, guid: d81d794e3f1b3064db4509b0df92be92, type: 3}
    portraitPosition: 1
    typingSpeed: 0.02
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: -3590566777017096083, guid: ffe0f79a1be1bc745ba03d7de9427399, type: 3}
  - speakerName: "\u30D2\u30A4\u30E9\u30AE"
    text: "\u30EA\u30C9\u3055\u3093\u306F\u3001\u9CE5\u3067\u306F\u306A\u304B\u3063\u305F\u3002\u9CE5\u306B\u61A7\u308C\u3066\u3001\u9CE5\u306B\u98DF\u3079\u3089\u308C\u305F\u2026\u2026\u30A2\u30AA\u30E0\u30B7\u3060\u3063\u305F\u3002"
    portrait: {fileID: 21300000, guid: f3f65e03f4cbec441b408057920c5ed9, type: 3}
    portraitPosition: 2
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 21300000, guid: 46ba3d3eeddf56c4a98e1affe0a01baa, type: 3}
  - speakerName: "\u30D2\u30A4\u30E9\u30AE"
    text: "\u3053\u306E\u771F\u5B9F\u3092\u3001\u305D\u306E\u307E\u307E\u4F1D\u3048\u308B\u3079\u304D\u306A\u306E\u2026\u2026\uFF1F"
