  - speakerName: "\u30EA\u30C9"
    text: "\u3044\u3048\u3002\u7FFC\u304C\u3042\u308B\u306A\u3089\u9CE5\u3067\u3057\u3087\u3046\uFF1F\u3000\u30DC\u30AF\u306F\u7A7A\u306B\u3044\u308B\u3079\u304D\u306A\u3093\u3067\u3059\u3002"
