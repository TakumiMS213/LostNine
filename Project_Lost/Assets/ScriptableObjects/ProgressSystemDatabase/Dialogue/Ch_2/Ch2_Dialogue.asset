  - speakerName: "\u30EA\u30C9"
    text: "\u30DC\u30AF\u306F\u30EA\u30C9\u3002\u9AD8\u8CB4\u306A\u30EF\u30BF\u30EA\u30C9\u30EA\u3067\u3059\u3002\u2026\u2026\u305F\u3076\u3093\u3001\u304D\u3063\u3068\u3002"
