  - speakerName: "\u30D2\u30A4\u30E9\u30AE"
    text: "\u597D\u304D\u306A\u3082\u306E\u3092\u805E\u3044\u3066\u3082\u3044\u3044\u3067\u3059\u304B\uFF1F\u3000\u306A\u304F\u3057\u3082\u306E\u306E\u624B\u304C\u304B\u308A\u306B\u306A\u308B\u306E\u3067\u3002"
