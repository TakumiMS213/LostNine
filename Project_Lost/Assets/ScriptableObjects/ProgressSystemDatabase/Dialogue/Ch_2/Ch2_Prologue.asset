%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d1419a330f93d40d0a6036a06f49986d, type: 3}
  m_Name: Ch2_Prologue
  m_EditorClassIdentifier: 
  entries:
  - speakerName: "カチョウ"
    text: "...さて、こんなところかね。"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "ヒイラギ"
    text: "うぅ....むずかしい...."
    portrait: {fileID: 21300000, guid: a3a23cdd243ef5d4582280f5a9d0c6e1, type: 3}
    portraitPosition: 2
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "カチョウ"
    text: "あとは実際にナクシビトを対応できると良いんだが...."
    portrait: {fileID: 21300000, guid: 3e9209ca9223746229eb325d4a7984f9, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "ヒイラギ"
    text: "で、でもそんな都合よく現れたり...."
    portrait: {fileID: 21300000, guid: a3a23cdd243ef5d4582280f5a9d0c6e1, type: 3}
    portraitPosition: 2
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "リド"
    text: "あの....「遺失物管理課」はここですか...？"
    portrait: {fileID: 21300000, guid: 4b3a70eb92a7f7149b01cc2968185357, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "ヒイラギ"
    text: "するんだ....。"
    portrait: {fileID: 21300000, guid: f3f65e03f4cbec441b408057920c5ed9, type: 3}
    portraitPosition: 2
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "カチョウ"
    text: "....丁度いい。お前がやってみるんだ。"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "カチョウ"
    text: "アタシは裏でガソリンでも飲んでるよ。"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "カチョウ"
    text: "せいぜい頑張りな。"
    portrait: {fileID: 21300000, guid: 3e9209ca9223746229eb325d4a7984f9, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "ヒイラギ"
    text: "（うぅ...できるかな...）"
    portrait: {fileID: 21300000, guid: f3f65e03f4cbec441b408057920c5ed9, type: 3}
    portraitPosition: 2
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "ヒイラギ"
    text: "（でも命を助けられた？からにはやるしかない...）"
    portrait: {fileID: 21300000, guid: a3a23cdd243ef5d4582280f5a9d0c6e1, type: 3}
    portraitPosition: 2
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
