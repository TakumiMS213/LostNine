  entries:
  - speakerName: "\u30D2\u30A4\u30E9\u30AE"
    text: "\u30EA\u30C9\u3055\u3093\u3002\u3053\u308C\u306F\u3001\u3042\u306A\u305F\u304C\u65C5\u306E\u9014\u4E2D\u3067\u96C6\u3081\u3066\u3044\u305F\u6728\u306E\u8449\u306E\u30B3\u30EC\u30AF\u30B7\u30E7\u30F3\u3067\u3059\u3002"
