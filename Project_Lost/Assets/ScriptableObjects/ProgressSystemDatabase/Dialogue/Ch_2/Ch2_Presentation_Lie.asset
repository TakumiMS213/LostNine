    portraitPosition: 2
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 21300000, guid: 46ba3d3eeddf56c4a98e1affe0a01baa, type: 3}
  - speakerName: "\u30EA\u30C9"
    text: "\u307B\u3089\u3001\u3084\u3063\u3071\u308A\u30DC\u30AF\u306E\u8A00\u3046\u901A\u308A\u3060\uFF01\u3000\u30DC\u30AF\u306F\u9AD8\u8CB4\u306A\u30EF\u30BF\u30EA\u30C9\u30EA\u3067\u3001\u3053\u308C\u306F\u65C5\u306E\u8A18\u5FF5\u54C1\u3060\u3063\u305F\u3093\u3060\uFF01"
    portrait: {fileID: 21300000, guid: 18f1e5e075c94174f8da7df44219d63f, type: 3}
    portraitPosition: 1
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 21300000, guid: 46ba3d3eeddf56c4a98e1affe0a01baa, type: 3}
  - speakerName: "\u30EA\u30C9"
    text: "\u3042\u3042\u3001\u3059\u3063\u304D\u308A\u3057\u305F\u3002\u3053\u308C\u3067\u3084\u3063\u3068\u3001\u6B21\u306E\u7DBA\u9E97\u306A\u7A7A\u3078\u65C5\u7ACB\u3066\u308B\u3088\u3002"
    portrait: {fileID: 21300000, guid: 18f1e5e075c94174f8da7df44219d63f, type: 3}
    portraitPosition: 1
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 21300000, guid: 8f6b3314d28181b40888c6cece606878, type: 3}
  - speakerName: "\u30EA\u30C9"
    text: "\u5730\u9762\u3092\u9019\u3046\u3060\u3051\u306E\u5974\u3089\u3092\u3001\u4ECA\u5EA6\u3053\u305D\u8E0F\u307F\u3064\u3051\u306B\u306D\uFF01"
    portrait: {fileID: 21300000, guid: d81d794e3f1b3064db4509b0df92be92, type: 3}
    portraitPosition: 1
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 21300000, guid: 8f6b3314d28181b40888c6cece606878, type: 3}
  - speakerName: "\u30D2\u30A4\u30E9\u30AE"
    text: "\u2026\u2026\u7B11\u3063\u3066\u3044\u308B\u306E\u306B\u3001\u9B42\u306E\u5F62\u304C\u6B20\u3051\u3066\u3044\u304F\u3002"
    portrait: {fileID: 21300000, guid: f3f65e03f4cbec441b408057920c5ed9, type: 3}
    portraitPosition: 2
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 21300000, guid: 46ba3d3eeddf56c4a98e1affe0a01baa, type: 3}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u3053\u308C\u304C\u30ED\u30B9\u3060\u3002\u512A\u3057\u3044\u5618\u306F\u3001\u4E16\u754C\u306E\u5BFF\u547D\u3092\u5C11\u3057\u305A\u3064\u524A\u308B\u3002\u899A\u3048\u3066\u304A\u3051\u3002"
