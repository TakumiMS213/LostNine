  entries:
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u5168\u90E8\u898B\u3064\u3051\u305F\u3088\u3046\u3060\u306D\u3002\n"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u898B\u3064\u3051\u305F\u30AD\u30FC\u30EF\u30FC\u30C9\u306F<color=#0084ff>\u300C\u8A18\u61B6\u306E\u6B20\u7247\u300D</color>\u3068\u3057\u3066\u305D\u3053\u306E\u30CE\u30FC\u30C8\u306B\u8A18\u8FF0\u3055\u308C\u308B....\u306F\u305A\u306A\u3093\u3060\u304C\u3001\u4ECA\u306F\u5B9F\u88C5\u3057\u3066\u306A\u3044\u307F\u305F\u3044\u3060\u3002"
    portrait: {fileID: 21300000, guid: 3e9209ca9223746229eb325d4a7984f9, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u3053\u308C\u304B\u3089\u884C\u3046\u306E\u306F\u300C\u73FE\u50CF\uFF08\u30E1\u30E2\u30E9\u30A4\u30BA\uFF09\u300D\u3068\u3044\u3046\u4F5C\u696D\u3060\u3088\u3002"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u73FE\u50CF\u306B\u306F<color=#ff7b00>\u300C\u8ABF\u5F8B\u300D</color>\u3068<color=#ff7b00>\u300C\u5B9A\u7740\u300D</color>\u306E\uFF12\u3064\u306E\u30DF\u30CB\u30B2\u30FC\u30E0\u304C\u3042\u308B\u3002"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u300C\u8ABF\u5F8B\u300D\u3067\u306F\u30A8\u30EA\u30A2\u5185\u306E\u9069\u5207\u306A\u5834\u6240\u306B\u8D64\u3044\u70B9\u3092\u5408\u308F\u305B...\u3001"
    portrait: {fileID: 21300000, guid: 3e9209ca9223746229eb325d4a7984f9, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u300C\u5B9A\u7740\u300D\u3067\u306F\u5358\u7D14\u306A\u4E00\u7B46\u66F8\u304D\u30D1\u30BA\u30EB\u3092\u884C\u3063\u3066\u3082\u3089\u3046\u3002"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\uFF12\u3064\u3092\u30AF\u30EA\u30A2\u3057\u3066\u3001\u3088\u3046\u3084\u304F\u30B7\u30CA\u30EA\u30AA\u304C\u9032\u3080\u3063\u3066\u30EF\u30B1\u3060\u306A\u3002"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "\u305F\u3060\u3057\u3001\u5931\u6557\u3057\u3066\u3082\u30DA\u30CA\u30EB\u30C6\u30A3\u306F\u306A\u3044\u3088\u3002\n\u3042\u304F\u307E\u3067\u30B7\u30CA\u30EA\u30AA\u304C\u30E1\u30A4\u30F3\u3060\u304B\u3089\u306D\u3002"
    portrait: {fileID: 21300000, guid: 13979ae4426a346a99d92c1682e2c956, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
    backgroundImage: {fileID: 0}
  - speakerName: "\u30AB\u30C1\u30E7\u30A6"
    text: "...\u8AAC\u660E\u306F\u3053\u3093\u306A\u3068\u3053\u308D\u3060\u3002\n\u30B7\u30FC\u30F3\u304C\u5909\u308F\u308B\u3068\u3001\u30A2\u30BF\u30B7\u306F\u51FA\u3066\u3053\u3089\u308C\u306A\u3044\u3002\n\u9811\u5F35\u3063\u3066\u30AF\u30EA\u30A2\u3059\u308B\u3093\u3060\u306D\u3002"
    portrait: {fileID: 21300000, guid: 3e9209ca9223746229eb325d4a7984f9, type: 3}
    portraitPosition: 0
    typingSpeed: 0
    nameSlideDirection: 0
    voiceClip: {fileID: 0}
